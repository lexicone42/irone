{
    "Secdash": {
        "entityTypes": {
            "User": {
                "memberOfTypes": ["UserGroup"],
                "shape": {
                    "type": "Record",
                    "attributes": {
                        "email": { "type": "String" },
                        "sub": { "type": "String" }
                    }
                }
            },
            "UserGroup": {},
            "Resource": {
                "shape": {
                    "type": "Record",
                    "attributes": {
                        "owner": { "type": "Entity", "name": "User", "required": false },
                        "resourceType": { "type": "String" }
                    }
                }
            }
        },
        "actions": {
            "view:dashboard":       { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "view:monitoring":      { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "view:security_lake":   { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "test:security_lake":   { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "view:detections":      { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "create:detection":     { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "test:detection":       { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "query:data":           { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "ai:generate_rule":     { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "view:investigations":  { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "create:investigation": { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "view:investigation":   { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "enrich:investigation": { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "ai:analyze":           { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "export:investigation": { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "view:deploy":          { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "deploy:lambda":        { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "api:read":             { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "api:query":            { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } },
            "admin:manage":         { "appliesTo": { "principalTypes": ["User"], "resourceTypes": ["Resource"] } }
        }
    }
