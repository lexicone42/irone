#!/usr/bin/env bash
# Native pre-commit hook for irone (no Python/prek dependency)
set -e

cd "$(git rev-parse --show-toplevel)/irone-rs"

echo "── cargo fmt ──"
cargo fmt --check

echo "── cargo clippy ──"
cargo clippy --workspace -- -D warnings

echo "── cargo deny ──"
if command -v cargo-deny &>/dev/null; then
    cargo deny check
else
    echo "cargo-deny not installed, skipping"
fi

echo "✓ pre-commit checks passed"
